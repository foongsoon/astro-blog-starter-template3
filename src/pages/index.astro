    #fontControls button,
    #toggleMode,
    #toggleLang,
    #shareLink {
      padding: 5px 12px;
      font-size: 0.8rem;
    }

    h1 {
      margin-top: 80px;
    }

    p {
      font-size: 1.1rem;
    }

    #sutra {
      padding: 18px 16px;
    }
  }
</style>

<script>
  // 客户端交互逻辑（保留全部原有功能，并进行模块化优化）
  (function () {
    const toggleMode = document.getElementById("toggleMode");
    const toggleLang = document.getElementById("toggleLang");
    const zoomIn = document.getElementById("zoomIn");
    const zoomOut = document.getElementById("zoomOut");
    const videoCover = document.getElementById("videoCover");
    const amitabhaVideo = document.getElementById("amitabhaVideo");
    const sutraDiv = document.getElementById("sutra");
    const mainTitle = document.getElementById("mainTitle");
    const videoText = document.getElementById("videoText");
    const shareLinkButton = document.getElementById("shareLink");

    // 状态
    let currentLang = localStorage.getItem("prefLang") || "simplified";
    let isLight = localStorage.getItem("prefTheme") === "light";
    const savedFont = localStorage.getItem("prefFontSize");

    // 原始简体备份（用于转换）
    let originalSimplifiedHTML = "";

    // OpenCC 转换器
    let toTraditional = null;
    let toSimplified = null;

    const initConverters = () => {
      if (typeof OpenCC !== "undefined") {
        toTraditional = OpenCC.Converter({ from: "cn", to: "tw" });
        toSimplified = OpenCC.Converter({ from: "tw", to: "cn" });
      } else {
        setTimeout(initConverters, 100);
      }
    };
    initConverters();

    // 应用语言
    const applyLanguage = () => {
      if (!toTraditional || !toSimplified) return;
      if (currentLang === "traditional") {
        if (originalSimplifiedHTML) {
          sutraDiv.innerHTML = toTraditional(originalSimplifiedHTML);
        } else {
          sutraDiv.innerHTML = toTraditional(sutraDiv.innerHTML);
        }
        mainTitle.textContent = mainTitle.dataset.traditional;
        videoText.textContent = videoText.dataset.traditional;
        toggleLang.textContent = "简";
      } else {
        if (originalSimplifiedHTML) {
          sutraDiv.innerHTML = originalSimplifiedHTML;
        } else {
          sutraDiv.innerHTML = toSimplified(sutraDiv.innerHTML);
        }
        mainTitle.textContent = mainTitle.dataset.simplified;
        videoText.textContent = videoText.dataset.simplified;
        toggleLang.textContent = "繁";
      }
    };

    // 初始化备份
    const initOriginalBackup = () => {
      if (currentLang === "traditional" && toSimplified) {
        originalSimplifiedHTML = toSimplified(sutraDiv.innerHTML);
      } else {
        originalSimplifiedHTML = sutraDiv.innerHTML;
      }
      applyLanguage();
    };

    // 视频播放
    videoCover.addEventListener("click", () => {
      videoCover.style.display = "none";
      amitabhaVideo.style.display = "block";
      amitabhaVideo.play().catch((e) => console.log("自动播放被阻止:", e));
    });

    // 主题
    const applyTheme = () => {
      if (isLight) {
        document.body.classList.add("light");
        toggleMode.textContent = "暗";
      } else {
        document.body.classList.remove("light");
        toggleMode.textContent = "亮";
      }
    };

    if (isLight) document.body.classList.add("light");
    applyTheme();

    toggleMode.addEventListener("click", () => {
      isLight = !isLight;
      applyTheme();
      localStorage.setItem("prefTheme", isLight ? "light" : "dark");
    });

    // 字体大小
    if (savedFont) sutraDiv.style.fontSize = savedFont;

    zoomIn.addEventListener("click", () => {
      const currentSize = parseFloat(getComputedStyle(sutraDiv).fontSize);
      const newSize = Math.min(currentSize + 2, 36);
      sutraDiv.style.fontSize = newSize + "px";
      localStorage.setItem("prefFontSize", newSize + "px");
    });

    zoomOut.addEventListener("click", () => {
      const currentSize = parseFloat(getComputedStyle(sutraDiv).fontSize);
      const newSize = Math.max(currentSize - 2, 12);
      sutraDiv.style.fontSize = newSize + "px";
      localStorage.setItem("prefFontSize", newSize + "px");
    });

    // 简繁切换
    toggleLang.addEventListener("click", () => {
      if (currentLang === "traditional" && toSimplified) {
        originalSimplifiedHTML = toSimplified(sutraDiv.innerHTML);
      } else {
        originalSimplifiedHTML = sutraDiv.innerHTML;
      }
      currentLang = currentLang === "simplified" ? "traditional" : "simplified";
      localStorage.setItem("prefLang", currentLang);
      applyLanguage();
    });

    // 分享
    shareLinkButton.addEventListener("click", async () => {
      const url = "https://www.amtb.cc";
      try {
        await navigator.clipboard.writeText(url);
        alert(`链接已复制: ${url}`);
      } catch {
        alert(`请手动复制链接: ${url}`);
      }
    });

    // 确保备份初始化
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", () =>
        setTimeout(initOriginalBackup, 80)
      );
    } else {
      setTimeout(initOriginalBackup, 80);
    }
  })();
</script>
