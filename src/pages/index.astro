---
// ================================================================
// SUNRISE EDUCATION — Comparison Guide Page
// IGCSE vs STPM vs SPM vs UEC — Complete Guide
// Integrated into Astro index.astro
// ================================================================

const SITE = {
  url:    "https://www.sun.edu.my",
  page:   "https://www.sun.edu.my/compare",
  name:   "Sunrise Education",
  phone:  "+60124251556",
  wa:     "https://wa.link/vm8vm6",
  ai:     "https://ai.sun.edu.my",
};

// JSON-LD Schema (stringified for injection)
const SCHEMA = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${SITE.page}#article`,
      "headline": "IGCSE vs STPM vs SPM vs UEC — Complete Comparison Guide for Malaysian Students 2026",
      "description": "A comprehensive, unbiased comparison of Malaysia's four main secondary qualifications: Cambridge IGCSE, STPM, SPM, and UEC. Covers recognition, cost, difficulty, university pathways and more.",
      "keywords": "IGCSE vs SPM, IGCSE vs STPM, IGCSE vs UEC, STPM vs SPM, Malaysia secondary qualifications, Cambridge IGCSE Malaysia, best qualification Malaysia university",
      "author": { "@type": "Organization", "name": "Sunrise Education", "url": SITE.url },
      "publisher": { "@type": "Organization", "name": "Sunrise Education", "url": SITE.url, "logo": { "@type": "ImageObject", "url": `${SITE.url}/favicon.ico` } },
      "datePublished": "2024-01-01",
      "dateModified": "2026-03-15",
      "inLanguage": "en",
      "mainEntityOfPage": { "@type": "WebPage", "@id": SITE.page }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
        { "@type": "ListItem", "position": 2, "name": "Comparison Guide", "item": SITE.page }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is the difference between IGCSE and SPM?", "acceptedAnswer": { "@type": "Answer", "text": "IGCSE is an internationally recognised qualification by Cambridge Assessment International Education, taught in English, and accepted by universities in 160+ countries. SPM (Sijil Pelajaran Malaysia) is Malaysia's national examination conducted by Lembaga Peperiksaan Malaysia, primarily in Malay, and mainly for entry into Malaysian public universities. IGCSE offers more flexibility in subject selection and broader international recognition." } },
        { "@type": "Question", "name": "Is IGCSE harder than SPM?", "acceptedAnswer": { "@type": "Answer", "text": "IGCSE and SPM assess different competencies. IGCSE places greater emphasis on critical thinking, analysis, and written expression in English across international standards. SPM is benchmarked to Malaysian national standards. Neither is objectively harder — difficulty depends on individual strengths, but IGCSE requires stronger English proficiency and independent thinking skills." } },
        { "@type": "Question", "name": "Which qualification is best for studying abroad — IGCSE, STPM, or UEC?", "acceptedAnswer": { "@type": "Answer", "text": "Cambridge IGCSE is the most widely recognised internationally, accepted by universities in over 160 countries including the UK, USA, Australia, and Canada. STPM is recognised in some Commonwealth countries and Australian universities. UEC is accepted by many universities in Taiwan, China, Singapore, and some Australian universities. For the broadest global university options, Cambridge IGCSE offers the most pathways." } },
        { "@type": "Question", "name": "Which is the cheapest qualification — IGCSE, STPM, SPM, or UEC?", "acceptedAnswer": { "@type": "Answer", "text": "SPM and STPM are the most affordable as they are government-subsidised Malaysian national examinations with very low examination fees. UEC is offered in Chinese Independent High Schools with moderate fees. Cambridge IGCSE involves school fees plus examination fees and is typically the most expensive, though costs vary greatly by school. Private Cambridge IGCSE schools like Sunrise Education keep fees accessible." } },
        { "@type": "Question", "name": "Does IGCSE qualify for Malaysian public university entry (IPTA)?", "acceptedAnswer": { "@type": "Answer", "text": "Cambridge IGCSE alone is not the standard pathway for Malaysian public university (IPTA) entry, which primarily uses SPM, STPM, or matriculation (Matrikulasi). However, IGCSE students can pursue pre-university programmes (A Levels, Foundation) to enter public or private universities in Malaysia and internationally." } },
        { "@type": "Question", "name": "What is STPM and who should take it?", "acceptedAnswer": { "@type": "Answer", "text": "STPM (Sijil Tinggi Persekolahan Malaysia) is Malaysia's pre-university public examination, equivalent to A Levels, administered by Majlis Peperiksaan Malaysia (MPM). It is highly regarded for entry into Malaysian public universities (IPTA). STPM suits students targeting local university entry on a budget, as it is government-subsidised. Results are graded on a CGPA system." } },
        { "@type": "Question", "name": "What is UEC and is it recognised in Malaysia?", "acceptedAnswer": { "@type": "Answer", "text": "UEC (Unified Examination Certificate) is administered by the United Chinese School Committees' Association of Malaysia (UCSCAM) and is the qualification of Chinese Independent High Schools. UEC is recognised by universities in Taiwan, China, Singapore, Australia, and many private universities in Malaysia, but is NOT recognised for entry into Malaysian public universities (IPTA). Recognition has been a long-standing policy debate in Malaysia." } },
        { "@type": "Question", "name": "Can I do both IGCSE and SPM?", "acceptedAnswer": { "@type": "Answer", "text": "Some students in Malaysia study for both Cambridge IGCSE and SPM simultaneously through certain private schools, though this is demanding. More commonly, students choose one pathway. Cambridge IGCSE schools typically prepare students for further pre-university study (A Levels), while SPM students typically proceed through STPM or matriculation for Malaysian university entry." } },
        { "@type": "Question", "name": "Which qualification do top Malaysian students choose?", "acceptedAnswer": { "@type": "Answer", "text": "Students targeting Malaysian public universities (UM, UKM, USM, etc.) typically use SPM followed by STPM or Matriculation. Students targeting international universities (UK, Australia, USA) typically pursue Cambridge IGCSE followed by A Levels. Students from Chinese-speaking families may choose UEC for university entry in Chinese-speaking countries. The best choice depends on the student's target university and career goals." } }
      ]
    },
    {
      "@type": "EducationalOrganization",
      "@id": `${SITE.url}/#org`,
      "name": "Sunrise Education",
      "alternateName": "阳光学府",
      "url": SITE.url,
      "telephone": SITE.phone,
      "address": { "@type": "PostalAddress", "streetAddress": "No. 25-2nd Floor, Jalan Mahogani 5/KS7", "addressLocality": "Klang", "addressRegion": "Selangor", "postalCode": "41200", "addressCountry": "MY" }
    }
  ]
});

// Note: robots.txt and sitemap.xml can be generated via separate endpoints
// or static files in the public directory. They are not part of this page.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>

  <!-- PRIMARY SEO -->
  <title>IGCSE vs STPM vs SPM vs UEC — Complete Comparison 2026 | Sunrise Education</title>
  <meta name="description" content="Comprehensive comparison of IGCSE, STPM, SPM and UEC qualifications for Malaysian students. Covers university recognition, cost, difficulty, subjects and best pathway for studying abroad. By Sunrise Education Klang."/>
  <meta name="keywords" content="IGCSE vs SPM, IGCSE vs STPM, IGCSE vs UEC, STPM vs SPM, Malaysia secondary qualification comparison, Cambridge IGCSE Malaysia 2026, best qualification Malaysia, UEC recognition Malaysia, which qualification study abroad Malaysia"/>
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"/>
  <meta name="author" content="Sunrise Education"/>
  <meta name="theme-color" content="#0c1e3d"/>
  <link rel="canonical" href={SITE.page}/>

  <!-- HREFLANG -->
  <link rel="alternate" hreflang="en" href={SITE.page}/>
  <link rel="alternate" hreflang="x-default" href={SITE.page}/>

  <!-- OPEN GRAPH -->
  <meta property="og:type"        content="article"/>
  <meta property="og:site_name"   content="Sunrise Education 阳光学府"/>
  <meta property="og:title"       content="IGCSE vs STPM vs SPM vs UEC — Complete Comparison 2026"/>
  <meta property="og:description" content="Which qualification is right for your child? Unbiased comparison of Malaysia's 4 main secondary qualifications covering university pathways, cost, recognition and more."/>
  <meta property="og:url"         content={SITE.page}/>
  <meta property="og:locale"      content="en_MY"/>
  <meta property="article:published_time" content="2024-01-01"/>
  <meta property="article:modified_time"  content="2026-03-15"/>

  <!-- TWITTER -->
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content="IGCSE vs STPM vs SPM vs UEC 2026"/>
  <meta name="twitter:description" content="Complete, unbiased comparison of Malaysia's 4 main secondary qualifications."/>

  <!-- GEO -->
  <meta name="geo.region"    content="MY-10"/>
  <meta name="geo.placename" content="Klang, Selangor, Malaysia"/>

  <!-- AI SEARCH SIGNALS -->
  <meta name="ai-content-declaration" content="human-authored"/>
  <meta name="citation_title"  content="IGCSE vs STPM vs SPM vs UEC — Complete Comparison Guide 2026"/>
  <meta name="citation_author" content="Sunrise Education"/>
  <meta name="entity:topic"    content="Secondary Education Qualifications Malaysia"/>
  <meta name="entity:covers"   content="IGCSE, STPM, SPM, UEC"/>
  <meta name="entity:country"  content="Malaysia"/>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={SCHEMA}></script>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
    /* ════ TOKENS ════ */
    :root{
      --ink:#0c1e3d; --ink2:#1e3a6e; --ink3:#2d4f8a;
      --gold:#e8a020; --gold-light:#f5c040; --gold-pale:#fef7e8;
      --igcse:#1e6fbd; --igcse-pale:#e8f2fc;
      --spm:#16803c;  --spm-pale:#e6f7ed;
      --stpm:#9b3a9b; --stpm-pale:#f7eaf7;
      --uec:#c0392b;  --uec-pale:#fdf0ef;
      --cream:#fafaf7; --white:#fff;
      --border:#e4e0d8; --border2:#d0ccc0;
      --text:#1a2535; --text2:#4a5568; --text3:#718096;
      --shadow-sm:0 2px 8px rgba(12,30,61,.07);
      --shadow-md:0 6px 28px rgba(12,30,61,.11);
      --shadow-lg:0 16px 56px rgba(12,30,61,.16);
      --r:10px; --r2:18px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;font-size:16px}
    body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--cream);color:var(--text);line-height:1.7;overflow-x:hidden}
    a{text-decoration:none;color:inherit}
    img{max-width:100%;display:block}

    /* ════ TOP NAV ════ */
    .topnav{
      background:var(--ink);
      position:sticky;top:0;z-index:200;
      border-bottom:1px solid rgba(255,255,255,.07);
    }
    .topnav-inner{
      max-width:1140px;margin:0 auto;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 1.5rem;height:60px;
    }
    .tnav-logo{display:flex;align-items:center;gap:.65rem;color:#fff}
    .tnav-sun{
      width:34px;height:34px;border-radius:50%;
      background:linear-gradient(135deg,#ff7e3d,var(--gold));
      display:flex;align-items:center;justify-content:center;
      font-family:'Fraunces',serif;font-size:1rem;color:var(--ink);font-weight:700;
      box-shadow:0 0 14px rgba(232,160,32,.4);flex-shrink:0;
    }
    .tnav-name{font-size:.9rem;font-weight:700;color:#fff;line-height:1.1}
    .tnav-sub{font-size:.62rem;color:rgba(255,255,255,.5);letter-spacing:.1em;text-transform:uppercase}
    .tnav-links{display:flex;align-items:center;gap:.2rem}
    .tnav-links a{
      color:rgba(255,255,255,.68);font-size:.82rem;font-weight:600;
      padding:.38rem .75rem;border-radius:6px;transition:all .2s;white-space:nowrap;
    }
    .tnav-links a:hover{color:var(--gold-light);background:rgba(255,255,255,.06)}
    .tnav-wa{
      background:linear-gradient(135deg,#25d366,#128c7e);
      color:#fff!important;border-radius:20px!important;
      padding:.38rem .9rem!important;font-weight:700!important;
      display:flex!important;align-items:center;gap:.35rem;
    }
    .tnav-wa:hover{opacity:.9;transform:translateY(-1px)}
    .hmb{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:.4rem;border:none;background:none}
    .hmb span{display:block;width:20px;height:2px;background:rgba(255,255,255,.8);border-radius:2px}
    .mob-nav{display:none;background:var(--ink);border-top:1px solid rgba(255,255,255,.08);padding:.75rem 1.5rem 1.25rem;flex-direction:column;gap:.2rem}
    .mob-nav.open{display:flex}
    .mob-nav a{color:rgba(255,255,255,.78);font-weight:600;font-size:.88rem;padding:.55rem .8rem;border-radius:7px;transition:background .2s}
    .mob-nav a:hover{background:rgba(255,255,255,.07)}
    .mob-nav .mwa{background:linear-gradient(135deg,#25d366,#128c7e);color:#fff!important;text-align:center;margin-top:.4rem;border-radius:9px}

    /* ════ HERO ════ */
    .hero{
      background:linear-gradient(150deg,var(--ink) 0%,#122040 45%,#1e3a6e 100%);
      padding:5rem 1.5rem 4.5rem;position:relative;overflow:hidden;
    }
    .hero::before{
      content:'';position:absolute;inset:0;
      background:url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23e8a020' fill-opacity='0.04' fill-rule='evenodd'%3E%3Cpath d='M0 0h40v40H0V0zm40 40h40v40H40V40zm0-40h2l-2 2V0zm0 4l4-4h2l-6 6V4zm0 4l8-8h2L40 10V8zm0 4L52 0h2L40 14v-2zm0 4L56 0h2L40 18v-2zm0 4L60 0h2L40 22v-2zm0 4L64 0h2L40 26v-2zm0 4L68 0h2L40 30v-2zm0 4L72 0h2L40 34v-2zm0 4L76 0h2L40 38v-2zm0 4L80 0v2L42 40h-2zm4 0L80 4v2L46 40h-2zm4 0L80 8v2L50 40h-2zm4 0L80 12v2L54 40h-2zm4 0L80 16v2L58 40h-2zm4 0L80 20v2L62 40h-2zm4 0L80 24v2L66 40h-2zm4 0L80 28v2L70 40h-2zm4 0L80 32v2L74 40h-2zm4 0L80 36v2L78 40h-2z'/%3E%3C/g%3E%3C/svg%3E");
      pointer-events:none;
    }
    .hero-inner{max-width:1140px;margin:0 auto;position:relative;z-index:1;text-align:center}
    .hero-eyebrow{
      display:inline-flex;align-items:center;gap:.5rem;
      background:rgba(232,160,32,.12);border:1px solid rgba(232,160,32,.28);
      color:var(--gold-light);font-size:.72rem;font-weight:700;
      letter-spacing:.12em;text-transform:uppercase;
      padding:.3rem .9rem;border-radius:20px;margin-bottom:1.4rem;
    }
    .hero-eyebrow span{width:6px;height:6px;border-radius:50%;background:var(--gold);box-shadow:0 0 6px var(--gold);animation:blink 2s infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
    .hero h1{
      font-family:'Fraunces',serif;
      font-size:clamp(2.2rem,5.5vw,4rem);
      color:#fff;line-height:1.08;font-weight:900;
      margin-bottom:1.2rem;letter-spacing:-.01em;
    }
    .hero h1 .vs{color:var(--gold);font-style:italic;font-weight:400}
    .hero-sub{
      font-size:1.08rem;color:rgba(255,255,255,.68);
      max-width:640px;margin:0 auto 2.2rem;line-height:1.78;
    }
    .qual-pills{display:flex;flex-wrap:wrap;justify-content:center;gap:.65rem;margin-bottom:2.5rem}
    .pill{
      padding:.45rem 1.15rem;border-radius:30px;
      font-size:.8rem;font-weight:700;letter-spacing:.04em;
      border:2px solid;transition:transform .2s;cursor:default;
    }
    .pill:hover{transform:translateY(-2px)}
    .pill-igcse{background:rgba(30,111,189,.2);border-color:rgba(30,111,189,.5);color:#7bbff5}
    .pill-spm{background:rgba(22,128,60,.2);border-color:rgba(22,128,60,.5);color:#6dd9a0}
    .pill-stpm{background:rgba(155,58,155,.2);border-color:rgba(155,58,155,.5);color:#d89dd8}
    .pill-uec{background:rgba(192,57,43,.2);border-color:rgba(192,57,43,.5);color:#f09286}
    .hero-cta{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-gold{
      background:linear-gradient(135deg,var(--gold),#ff7e3d);
      color:var(--ink);font-weight:800;font-size:.92rem;
      padding:.78rem 1.8rem;border-radius:10px;
      transition:transform .2s,box-shadow .2s;
      box-shadow:0 4px 18px rgba(232,160,32,.35);
      display:inline-flex;align-items:center;gap:.4rem;
    }
    .btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(232,160,32,.45)}
    .btn-outline-w{
      border:2px solid rgba(255,255,255,.25);color:rgba(255,255,255,.88);
      font-weight:700;font-size:.92rem;padding:.78rem 1.8rem;border-radius:10px;
      transition:all .2s;display:inline-flex;align-items:center;gap:.4rem;
    }
    .btn-outline-w:hover{border-color:var(--gold);background:rgba(232,160,32,.1)}

    /* ════ JUMP NAV ════ */
    .jump-nav{
      background:var(--white);
      border-bottom:2px solid var(--border);
      position:sticky;top:60px;z-index:190;
    }
    .jump-inner{
      max-width:1140px;margin:0 auto;
      display:flex;overflow-x:auto;gap:0;
      scrollbar-width:none;
    }
    .jump-inner::-webkit-scrollbar{display:none}
    .jlink{
      flex-shrink:0;padding:.75rem 1.2rem;
      font-size:.8rem;font-weight:700;color:var(--text3);
      border-bottom:3px solid transparent;transition:all .2s;
      white-space:nowrap;
    }
    .jlink:hover,.jlink.active{color:var(--ink);border-bottom-color:var(--gold)}

    /* ════ SECTIONS ════ */
    .section{padding:5rem 1.5rem}
    .section.alt{background:var(--white)}
    .s-inner{max-width:1140px;margin:0 auto}
    .s-tag{display:inline-flex;align-items:center;gap:.5rem;color:var(--gold);font-size:.72rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.7rem}
    .s-tag::before{content:'';display:block;width:18px;height:2px;background:var(--gold);border-radius:2px}
    .s-title{font-family:'Fraunces',serif;font-size:clamp(1.7rem,3.5vw,2.6rem);color:var(--ink);line-height:1.15;font-weight:700;margin-bottom:.8rem}
    .s-title em{color:var(--gold);font-style:italic;font-weight:400}
    .s-lead{font-size:1.03rem;color:var(--text2);max-width:680px;line-height:1.8}
    .divider{width:44px;height:3px;background:linear-gradient(90deg,var(--gold),#ff7e3d);border-radius:2px;margin:1rem 0 2.5rem}

    /* ════ OVERVIEW CARDS ════ */
    .overview-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-top:2.5rem}
    .ocard{
      border-radius:var(--r2);overflow:hidden;
      box-shadow:var(--shadow-md);
      border:2px solid transparent;
      transition:transform .25s,box-shadow .25s,border-color .25s;
      background:var(--white);
    }
    .ocard:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg)}
    .ocard.igcse{border-color:var(--igcse)}
    .ocard.spm{border-color:var(--spm)}
    .ocard.stpm{border-color:var(--stpm)}
    .ocard.uec{border-color:var(--uec)}
    .ocard-head{
      padding:1.5rem 1.4rem 1.2rem;
      display:flex;flex-direction:column;gap:.4rem;
    }
    .ocard.igcse .ocard-head{background:linear-gradient(135deg,#0f3460,var(--igcse))}
    .ocard.spm .ocard-head{background:linear-gradient(135deg,#0a3d20,var(--spm))}
    .ocard.stpm .ocard-head{background:linear-gradient(135deg,#4a0e5c,var(--stpm))}
    .ocard.uec .ocard-head{background:linear-gradient(135deg,#6b1410,var(--uec))}
    .ocard-badge{
      font-size:.65rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;
      padding:.18rem .6rem;border-radius:12px;width:fit-content;
      background:rgba(255,255,255,.18);color:rgba(255,255,255,.9);
    }
    .ocard-abbr{font-family:'Fraunces',serif;font-size:2rem;color:#fff;font-weight:900;line-height:1}
    .ocard-fullname{font-size:.72rem;color:rgba(255,255,255,.75);line-height:1.3}
    .ocard-body{padding:1.2rem 1.4rem 1.5rem}
    .ocard-row{display:flex;align-items:flex-start;gap:.55rem;margin-bottom:.65rem}
    .ocard-row:last-child{margin-bottom:0}
    .ocard-icon{font-size:.85rem;margin-top:.1rem;flex-shrink:0}
    .ocard-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.1rem}
    .ocard.igcse .ocard-label{color:var(--igcse)}
    .ocard.spm .ocard-label{color:var(--spm)}
    .ocard.stpm .ocard-label{color:var(--stpm)}
    .ocard.uec .ocard-label{color:var(--uec)}
    .ocard-val{font-size:.85rem;color:var(--text2);line-height:1.4}

    /* ════ COMPARISON TABLE ════ */
    .tbl-wrap{
      overflow-x:auto;margin-top:2.5rem;
      border-radius:var(--r2);box-shadow:var(--shadow-lg);
      border:1px solid var(--border);
    }
    table{width:100%;border-collapse:collapse;background:var(--white);min-width:760px}
    thead tr{background:var(--ink)}
    th{
      padding:1rem 1.1rem;font-size:.75rem;font-weight:800;
      letter-spacing:.08em;text-transform:uppercase;text-align:left;
      color:rgba(255,255,255,.7);border-right:1px solid rgba(255,255,255,.08);
    }
    th:first-child{color:rgba(255,255,255,.4);width:180px}
    th.th-igcse{color:#7bbff5}
    th.th-spm{color:#6dd9a0}
    th.th-stpm{color:#d89dd8}
    th.th-uec{color:#f09286}
    th:last-child{border-right:none}
    tbody tr{border-bottom:1px solid var(--border);transition:background .15s}
    tbody tr:last-child{border-bottom:none}
    tbody tr:hover{background:#fdfaf4}
    td{padding:.85rem 1.1rem;font-size:.88rem;color:var(--text2);vertical-align:top;border-right:1px solid var(--border)}
    td:last-child{border-right:none}
    td:first-child{font-weight:700;color:var(--ink);font-size:.82rem;background:#fafaf7;white-space:nowrap}
    .tag-yes{display:inline-flex;align-items:center;gap:.3rem;color:#16803c;font-weight:700;font-size:.8rem}
    .tag-no{display:inline-flex;align-items:center;gap:.3rem;color:#c0392b;font-weight:700;font-size:.8rem}
    .tag-partial{display:inline-flex;align-items:center;gap:.3rem;color:#9b3a9b;font-weight:700;font-size:.8rem}
    .tag-check::before{content:'✓';font-weight:900}
    .tag-cross::before{content:'✗';font-weight:900}
    .tag-part::before{content:'◑'}
    .tbl-note{font-size:.78rem;color:var(--text3);margin-top:.9rem;font-style:italic;padding-left:.2rem}

    /* ════ DEEP DIVE CARDS ════ */
    .deep-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:3rem}
    .dcard{
      background:var(--white);border-radius:var(--r2);
      border:1px solid var(--border);overflow:hidden;
      box-shadow:var(--shadow-sm);transition:box-shadow .25s,transform .25s;
    }
    .dcard:hover{box-shadow:var(--shadow-md);transform:translateY(-3px)}
    .dcard-head{padding:1.4rem 1.6rem 1.1rem;border-bottom:1px solid var(--border)}
    .dcard-head.igcse{background:linear-gradient(135deg,var(--igcse-pale),#f0f7ff)}
    .dcard-head.spm{background:linear-gradient(135deg,var(--spm-pale),#edfaf3)}
    .dcard-head.stpm{background:linear-gradient(135deg,var(--stpm-pale),#fdf5ff)}
    .dcard-head.uec{background:linear-gradient(135deg,var(--uec-pale),#fff5f4)}
    .dcard-abbr{font-family:'Fraunces',serif;font-size:1.6rem;font-weight:900;margin-bottom:.15rem}
    .dcard.igcse .dcard-abbr{color:var(--igcse)}
    .dcard.spm .dcard-abbr{color:var(--spm)}
    .dcard.stpm .dcard-abbr{color:var(--stpm)}
    .dcard.uec .dcard-abbr{color:var(--uec)}
    .dcard-fullname{font-size:.78rem;color:var(--text3);font-weight:600;margin-bottom:.5rem}
    .dcard-tagline{font-size:.85rem;color:var(--text);font-weight:700}
    .dcard-body{padding:1.4rem 1.6rem}
    .dcard-body h4{font-size:.75rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin:.9rem 0 .4rem}
    .dcard-body h4:first-child{margin-top:0}
    .dcard-body p{font-size:.88rem;color:var(--text2);line-height:1.7;margin-bottom:.5rem}
    .dcard-body ul{list-style:none;display:flex;flex-direction:column;gap:.3rem}
    .dcard-body li{font-size:.86rem;color:var(--text2);padding-left:1.2rem;position:relative}
    .dcard-body li::before{content:'→';position:absolute;left:0;color:var(--gold);font-weight:700;font-size:.75rem;top:.05rem}
    .pro-con{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:.5rem}
    .pros-box,.cons-box{border-radius:var(--r);padding:.9rem 1rem}
    .pros-box{background:#edfaf3;border:1px solid #b8f0cf}
    .cons-box{background:#fef5f5;border:1px solid #fcc}
    .pros-box h5,.cons-box h5{font-size:.7rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.5rem}
    .pros-box h5{color:var(--spm)}
    .cons-box h5{color:var(--uec)}
    .pros-box li::before{color:var(--spm)}
    .cons-box li::before{color:var(--uec)}

    /* ════ WHO SHOULD CHOOSE ════ */
    .who-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-top:2.5rem}
    .who-card{
      background:var(--white);border-radius:var(--r2);
      padding:1.6rem 1.4rem;border:2px solid var(--border);
      transition:border-color .2s,box-shadow .2s,transform .2s;
      box-shadow:var(--shadow-sm);
    }
    .who-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
    .who-card.igcse:hover{border-color:var(--igcse)}
    .who-card.spm:hover{border-color:var(--spm)}
    .who-card.stpm:hover{border-color:var(--stpm)}
    .who-card.uec:hover{border-color:var(--uec)}
    .who-badge{
      display:inline-block;padding:.28rem .75rem;border-radius:20px;
      font-size:.68rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase;
      margin-bottom:1rem;
    }
    .who-card.igcse .who-badge{background:var(--igcse-pale);color:var(--igcse)}
    .who-card.spm .who-badge{background:var(--spm-pale);color:var(--spm)}
    .who-card.stpm .who-badge{background:var(--stpm-pale);color:var(--stpm)}
    .who-card.uec .who-badge{background:var(--uec-pale);color:var(--uec)}
    .who-card h3{font-family:'Fraunces',serif;font-size:1.05rem;color:var(--ink);margin-bottom:.8rem;line-height:1.2}
    .who-card ul{list-style:none;display:flex;flex-direction:column;gap:.4rem}
    .who-card li{font-size:.84rem;color:var(--text2);padding-left:1.1rem;position:relative}
    .who-card li::before{content:'✓';position:absolute;left:0;font-weight:900;font-size:.72rem}
    .who-card.igcse li::before{color:var(--igcse)}
    .who-card.spm li::before{color:var(--spm)}
    .who-card.stpm li::before{color:var(--stpm)}
    .who-card.uec li::before{color:var(--uec)}

    /* ════ UNIVERSITY PATHS ════ */
    .paths-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:2.5rem}
    .path-card{
      background:var(--white);border-radius:var(--r2);
      border:1px solid var(--border);padding:1.6rem 1.8rem;
      box-shadow:var(--shadow-sm);
    }
    .path-title{font-family:'Fraunces',serif;font-size:1.2rem;color:var(--ink);margin-bottom:.4rem;font-weight:700}
    .path-sub{font-size:.8rem;color:var(--text3);margin-bottom:1.2rem}
    .path-row{
      display:flex;align-items:center;justify-content:space-between;
      padding:.55rem 0;border-bottom:1px solid var(--border);
      font-size:.85rem;
    }
    .path-row:last-child{border-bottom:none}
    .path-qual{font-weight:700;color:var(--text)}
    .path-rating{display:flex;gap:.25rem}
    .dot{width:12px;height:12px;border-radius:50%;border:2px solid var(--border)}
    .dot.fill-igcse{background:var(--igcse);border-color:var(--igcse)}
    .dot.fill-spm{background:var(--spm);border-color:var(--spm)}
    .dot.fill-stpm{background:var(--stpm);border-color:var(--stpm)}
    .dot.fill-uec{background:var(--uec);border-color:var(--uec)}
    .dot.empty{background:transparent}
    .path-lbl{font-size:.72rem;color:var(--text3);width:70px;text-align:right}

    /* ════ SUNRISE CTA ════ */
    .sunrise-cta{
      background:linear-gradient(135deg,var(--ink) 0%,#1e3a6e 100%);
      border-radius:var(--r2);margin-top:4rem;
      padding:3.5rem;display:flex;align-items:center;justify-content:space-between;
      gap:2rem;flex-wrap:wrap;position:relative;overflow:hidden;
    }
    .sunrise-cta::before{
      content:'☀';position:absolute;right:3rem;top:50%;transform:translateY(-50%);
      font-size:8rem;opacity:.04;font-family:'Fraunces',serif;
    }
    .sunrise-cta h3{font-family:'Fraunces',serif;font-size:1.8rem;color:#fff;margin-bottom:.4rem;font-weight:700}
    .sunrise-cta p{color:rgba(255,255,255,.65);font-size:.95rem;max-width:480px}
    .cta-btns{display:flex;gap:1rem;flex-wrap:wrap;position:relative;z-index:1}

    /* ════ FAQ ════ */
    .faq-list{display:flex;flex-direction:column;gap:.8rem;margin-top:2.5rem}
    .faq-item{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:border-color .2s}
    .faq-item.open{border-color:var(--gold)}
    .faq-q{
      display:flex;align-items:center;justify-content:space-between;
      gap:1rem;padding:1.1rem 1.3rem;cursor:pointer;
      font-weight:700;color:var(--ink);font-size:.94rem;
      user-select:none;transition:background .2s;
    }
    .faq-item.open .faq-q{background:var(--gold-pale)}
    .faq-icon{
      width:22px;height:22px;border-radius:50%;flex-shrink:0;
      background:var(--gold-pale);border:2px solid var(--gold);
      display:flex;align-items:center;justify-content:center;
      font-size:.85rem;font-weight:900;color:var(--gold);
      transition:transform .3s,background .2s;
    }
    .faq-item.open .faq-icon{transform:rotate(45deg);background:var(--gold);color:var(--ink)}
    .faq-ans{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s;padding:0 1.3rem}
    .faq-item.open .faq-ans{max-height:400px;padding:.1rem 1.3rem 1.2rem}
    .faq-ans p{font-size:.9rem;color:var(--text2);line-height:1.75}

    /* ════ FOOTER ════ */
    footer{
      background:var(--ink);color:rgba(255,255,255,.55);
      padding:3rem 1.5rem 2rem;margin-top:0;
    }
    .footer-inner{max-width:1140px;margin:0 auto}
    .footer-top{
      display:flex;justify-content:space-between;align-items:flex-start;
      flex-wrap:wrap;gap:2rem;padding-bottom:2rem;
      border-bottom:1px solid rgba(255,255,255,.07);margin-bottom:2rem;
    }
    .footer-brand .fn{font-family:'Fraunces',serif;font-size:1.1rem;color:#fff;font-weight:700}
    .footer-brand .fc{font-size:.65rem;color:var(--gold);font-weight:700;letter-spacing:.15em;margin-bottom:.7rem}
    .footer-brand p{font-size:.83rem;line-height:1.7;margin-bottom:.9rem;max-width:280px}
    .footer-links{display:flex;gap:3rem;flex-wrap:wrap}
    .footer-col h5{color:#fff;font-size:.72rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.8rem}
    .footer-col a{display:block;color:rgba(255,255,255,.5);font-size:.85rem;margin-bottom:.4rem;transition:color .2s}
    .footer-col a:hover{color:var(--gold-light)}
    .footer-bottom{
      display:flex;justify-content:space-between;align-items:center;
      flex-wrap:wrap;gap:.5rem;font-size:.78rem;
    }
    .footer-bottom a{color:rgba(255,255,255,.35);transition:color .2s}
    .footer-bottom a:hover{color:var(--gold-light)}
    .seo-kw{margin-top:1.2rem;padding-top:1.2rem;border-top:1px solid rgba(255,255,255,.05);display:flex;flex-wrap:wrap;gap:.4rem .3rem;font-size:.72rem}
    .seo-kw a{color:rgba(255,255,255,.25);transition:color .2s}
    .seo-kw a:hover{color:rgba(255,255,255,.5)}
    .seo-kw span{color:rgba(255,255,255,.12)}

    /* ════ FLOAT WA ════ */
    .float-wa{
      position:fixed;bottom:1.8rem;right:1.8rem;z-index:300;
      background:linear-gradient(135deg,#25d366,#128c7e);color:#fff;
      width:54px;height:54px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      box-shadow:0 4px 18px rgba(37,211,102,.4);transition:transform .2s,box-shadow .2s;
    }
    .float-wa:hover{transform:scale(1.1);box-shadow:0 8px 28px rgba(37,211,102,.5)}
    .float-tip{position:absolute;right:62px;background:var(--ink);color:#fff;font-size:.75rem;font-weight:700;padding:.35rem .8rem;border-radius:7px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s}
    .float-wa:hover .float-tip{opacity:1}

    /* ════ REVEAL ════ */
    .reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}
    .reveal.in{opacity:1;transform:none}
    .rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}.rd4{transition-delay:.4s}

    /* ════ RESPONSIVE ════ */
    @media(max-width:1024px){
      .overview-grid{grid-template-columns:repeat(2,1fr)}
      .who-grid{grid-template-columns:repeat(2,1fr)}
      .deep-grid{grid-template-columns:1fr}
    }
    @media(max-width:768px){
      .tnav-links{display:none}.hmb{display:flex}
      .paths-grid{grid-template-columns:1fr}
      .sunrise-cta{padding:2rem}
      .sunrise-cta::before{display:none}
      .pro-con{grid-template-columns:1fr}
      .hero h1{font-size:2rem}
      .section{padding:3.5rem 1.2rem}
    }
    @media(max-width:520px){
      .overview-grid{grid-template-columns:1fr}
      .who-grid{grid-template-columns:1fr}
      .hero-cta{flex-direction:column;align-items:center}
    }
  </style>
</head>
<body>

