<main id="main">

<!-- ════ OVERVIEW ════ -->
<section class="section" id="overview">
  <div class="s-inner">
    <div class="s-tag">At a Glance</div>
    <h2 class="s-title">Four Qualifications,<br/><em>Four Different Pathways</em></h2>
    <div class="divider"></div>
    <p class="s-lead">Malaysia offers students several routes through secondary education. Each has its own awarding body, target audience, and university access profile. Here's what each one means.</p>

    <div class="overview-grid reveal">
      <!-- IGCSE -->
      <div class="ocard igcse">
        <div class="ocard-head">
          <div class="ocard-badge">International</div>
          <div class="ocard-abbr">IGCSE</div>
          <div class="ocard-fullname">International General Certificate of Secondary Education</div>
        </div>
        <div class="ocard-body">
          <div class="ocard-row"><span class="ocard-icon">🏛</span><div><div class="ocard-label">Awarding Body</div><div class="ocard-val">Cambridge Assessment International Education (CAIE)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">📅</span><div><div class="ocard-label">Typical Age</div><div class="ocard-val">14–16 years</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🌍</span><div><div class="ocard-label">Language</div><div class="ocard-val">English (primarily)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🎓</span><div><div class="ocard-label">Recognition</div><div class="ocard-val">160+ countries worldwide</div></div></div>
        </div>
      </div>

      <!-- SPM -->
      <div class="ocard spm">
        <div class="ocard-head">
          <div class="ocard-badge">National (Malaysia)</div>
          <div class="ocard-abbr">SPM</div>
          <div class="ocard-fullname">Sijil Pelajaran Malaysia</div>
        </div>
        <div class="ocard-body">
          <div class="ocard-row"><span class="ocard-icon">🏛</span><div><div class="ocard-label">Awarding Body</div><div class="ocard-val">Lembaga Peperiksaan Malaysia (LPM)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">📅</span><div><div class="ocard-label">Typical Age</div><div class="ocard-val">16–17 years (Form 5)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🌍</span><div><div class="ocard-label">Language</div><div class="ocard-val">Malay (Bahasa Malaysia)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🎓</span><div><div class="ocard-label">Recognition</div><div class="ocard-val">Malaysia & select Commonwealth</div></div></div>
        </div>
      </div>

      <!-- STPM -->
      <div class="ocard stpm">
        <div class="ocard-head">
          <div class="ocard-badge">Pre-University (MY)</div>
          <div class="ocard-abbr">STPM</div>
          <div class="ocard-fullname">Sijil Tinggi Persekolahan Malaysia</div>
        </div>
        <div class="ocard-body">
          <div class="ocard-row"><span class="ocard-icon">🏛</span><div><div class="ocard-label">Awarding Body</div><div class="ocard-val">Majlis Peperiksaan Malaysia (MPM)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">📅</span><div><div class="ocard-label">Typical Age</div><div class="ocard-val">17–18 years (Form 6)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🌍</span><div><div class="ocard-label">Language</div><div class="ocard-val">Malay & English</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🎓</span><div><div class="ocard-label">Recognition</div><div class="ocard-val">Malaysia & some Commonwealth universities</div></div></div>
        </div>
      </div>

      <!-- UEC -->
      <div class="ocard uec">
        <div class="ocard-head">
          <div class="ocard-badge">Chinese Independent</div>
          <div class="ocard-abbr">UEC</div>
          <div class="ocard-fullname">Unified Examination Certificate</div>
        </div>
        <div class="ocard-body">
          <div class="ocard-row"><span class="ocard-icon">🏛</span><div><div class="ocard-label">Awarding Body</div><div class="ocard-val">United Chinese School Committees' Association (UCSCAM)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">📅</span><div><div class="ocard-label">Typical Age</div><div class="ocard-val">17–18 years</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🌍</span><div><div class="ocard-label">Language</div><div class="ocard-val">Chinese (Mandarin)</div></div></div>
          <div class="ocard-row"><span class="ocard-icon">🎓</span><div><div class="ocard-label">Recognition</div><div class="ocard-val">China, Taiwan, Singapore, some Australia; NOT Malaysian public universities</div></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ COMPARISON TABLE ════ -->
<section class="section alt" id="compare">
  <div class="s-inner">
    <div class="s-tag">Side by Side</div>
    <h2 class="s-title">Full Comparison<br/><em>Table</em></h2>
    <div class="divider"></div>
    <p class="s-lead">Every key dimension compared in one place, so you can make an informed decision for your child's future.</p>

    <div class="tbl-wrap reveal">
      <table>
        <thead>
          <tr>
